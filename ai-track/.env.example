# Copy to .env (gitignored) for local Phase 1–2 scripts only. Never ship in the extension.
GEMINI_API_KEY=

# Supabase worker (Phase 3 bridge): see ai-track/supabase/.env.example

# Optional overrides for grounding-smoke.mjs
# GEMINI_GROUNDING_MODEL=gemini-2.5-flash
# GEMINI_SMOKE_PROMPT=Who won UEFA Euro 2024?

# Optional: analyze-cli.mjs (Phase 2)
# GEMINI_ANALYZE_MODEL=gemini-2.5-flash

# Optional: multimodal-smoke.mjs
# GEMINI_MULTIMODAL_SMOKE_MODEL=gemini-2.5-flash
# GEMINI_MULTIMODAL_CAPTION=Only if you want multimodal-smoke to include post text
